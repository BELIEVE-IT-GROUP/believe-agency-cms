# Database
DATABASE_URI=postgres://agency_cms_user:PASSWORD@HOST:5432/agency_cms

# Payload
PAYLOAD_SECRET=change-me-minimum-32-chars-random-string
NEXT_PUBLIC_SERVER_URL=https://cms.believe-global.com

# Cloudflare R2 (S3-compatible storage)
R2_BUCKET=your-bucket-name
R2_ACCESS_KEY_ID=your-r2-access-key-id
R2_SECRET_ACCESS_KEY=your-r2-secret-access-key
R2_ENDPOINT=https://YOUR_ACCOUNT_ID.r2.cloudflarestorage.com
R2_PUBLIC_URL=https://your-r2-public-domain.com

# Email (Plunk SMTP)
SMTP_HOST=your-plunk-host
SMTP_PORT=587
SMTP_USER=your-plunk-user
SMTP_PASS=your-plunk-pass
SMTP_FROM_NAME=Believe Agency CMS
SMTP_FROM_ADDRESS=cms@believe-global.com
