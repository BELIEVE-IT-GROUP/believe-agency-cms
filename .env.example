# Database
DATABASE_URI=postgres://agency_cms_user:PASSWORD@HOST:5432/agency_cms

# Payload
PAYLOAD_SECRET=change-me-minimum-32-chars-random-string
NEXT_PUBLIC_SERVER_URL=https://cms.believe-global.com

# Cloudflare R2 (S3-compatible storage)
R2_BUCKET=your-bucket-name
R2_ACCESS_KEY_ID=your-r2-access-key-id
R2_SECRET_ACCESS_KEY=your-r2-secret-access-key
R2_ENDPOINT=https://YOUR_ACCOUNT_ID.r2.cloudflarestorage.com
R2_PUBLIC_URL=https://your-r2-public-domain.com

# Email (Plunk SMTP)
SMTP_HOST=your-plunk-host
SMTP_PORT=587
SMTP_USER=your-plunk-user
SMTP_PASS=your-plunk-pass
SMTP_FROM_NAME=Believe Agency CMS
SMTP_FROM_ADDRESS=cms@believe-global.com

# Frontend preview URL (for Payload Live Preview)
NEXT_PUBLIC_PREVIEW_URL=https://your-frontend.com

# Frontend ISR revalidation
# Same secret must be configured in each frontend deployment.
PAYLOAD_REVALIDATE_SECRET=change-me-revalidate-secret
# Optional override. If omitted, CMS calls NEXT_PUBLIC_PREVIEW_URL/api/revalidate.
PAYLOAD_REVALIDATE_WEBHOOK_URL=https://your-frontend.com/api/revalidate

# Forms / automations
DEFAULT_CONTACT_EMAIL=hello@believe-global.com
PLUNK_API_KEY=your-plunk-api-key

# Optional settings bootstrap
# Run with: npm run bootstrap:settings
BOOTSTRAP_TENANT_SLUG=clientex
BOOTSTRAP_SITE_NAME=Cliente X
BOOTSTRAP_SITE_DOMAIN=clientex.com
BOOTSTRAP_PREVIEW_URL=https://clientex.com
BOOTSTRAP_REVALIDATE_WEBHOOK_URL=https://clientex.com/api/revalidate
BOOTSTRAP_CONTACT_EMAIL=hello@clientex.com
BOOTSTRAP_PUBLIC_EMAIL=hello@clientex.com
